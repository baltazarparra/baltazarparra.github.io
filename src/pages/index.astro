---
import BaseLayout from "../layouts/BaseLayout.astro";
import { GithubLogoIcon } from "@phosphor-icons/react/ssr";
import { createElement } from "react";
import { renderToStaticMarkup } from "react-dom/server";
import ChromaText from "../components/ChromaText.astro";
import { site } from "../data/site";
import "../styles/home-rework.css";

const [primaryProject, ...secondaryProjects] = site.projects;
const companies = site.about.credits.split(", ");
const companyLoop = [...companies, ...companies, ...companies];
const chroma = {
  hero: ["baltz."],
  about: ["De", "sign ", "so", "lu", "tions ", "with ", "code ", "a", "gents ", "as ", "ar", "chi", "tec", "tu", "ral ", "com", "po", "nents."],
  writing: ["Lat", "est ", "notes."],
  projects: ["Sys", "tems ", "with ", "a ", "point ", "of ", "view."],
  clouds: ["my ", "lofi ", "ep"],
  elsewhere: ["Still ", "here."],
} as const;
const writingChroma = {
  "Sharing skills with NPX": ["Shar", "ing ", "skills ", "with ", "NPX"],
  "What is 'Harness Design' and why does it matter": ["What ", "is ", "'Har", "ness ", "De", "sign' ", "and ", "why ", "does ", "it ", "mat", "ter"],
} as const;
const projectChroma = {
  "AI-Native Engineering": ["AI-", "Na", "tive ", "En", "gi", "neer", "ing"],
  "Crypto Transfer DApp": ["Cryp", "to ", "Trans", "fer ", "DApp"],
  "Subtitle Scraping": ["Sub", "ti", "tle ", "Scrap", "ing"],
} as const;
const profileChroma = {
  LinkedIn: ["Linked", "In"],
  GitHub: ["Git", "Hub"],
  "dev.to": ["dev", ".to"],
  Spotify: ["Spot", "i", "fy"],
  "itch.io": ["itch", ".io"],
} as const;
const githubLogoSvg = renderToStaticMarkup(createElement(GithubLogoIcon, {
  className: "project-note-github",
  size: 24,
  weight: "fill",
  "aria-hidden": true,
  focusable: false,
}));
---

<BaseLayout>
  <a class="skip-link" href="#main">Skip to content</a>
  <div class="opening-loader" aria-hidden="true">
    <span>baltazarparra</span>
  </div>
  <div class="visual-field" aria-hidden="true"></div>
  <canvas class="unified-canvas" data-unified-canvas aria-hidden="true"></canvas>

  <main id="main" class="rework-home">
    <section class="scene hero" id="hero" aria-labelledby="hero-title" data-scroll-bend="0.58">
      <div class="hero-lockup">
        <h1 id="hero-title"><ChromaText segments={chroma.hero} /></h1>
        <div class="hero-meta" aria-label="Role and location" data-scroll-curve="0.9">
          <p>
            <span class="hero-role">{site.hero.role} at</span>
            <a href={site.hero.employerUrl} target="_blank" rel="noreferrer">
              {site.hero.employer}
            </a>
          </p>
          <p>{site.hero.location}</p>
        </div>
      </div>
      <div class="smile-slot" data-smile-slot aria-hidden="true"></div>
    </section>

    <section class="scene about" id="work" aria-labelledby="about-title" data-scroll-bend="1">
      <figure
        class="portrait-shell"
        data-liquid-slot
        data-liquid-mode="portrait"
        data-liquid-source="/baltz-portrait.webp"
        data-media-state="loading"
      >
        <img
          src="/baltz-portrait.webp"
          width="800"
          height="800"
          alt="Portrait of Baltazar Parra"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="about-copy">
        <p class="section-label">About</p>
        <h2 id="about-title"><ChromaText segments={chroma.about} /></h2>
        <div class="credits-marquee" data-credits-marquee data-scroll-rib="top bottom">
          <p class="sr-only">Collaborated with {site.about.credits}</p>
          <div class="credits-marquee-viewport" aria-hidden="true">
            <div class="credits-marquee-track" data-credits-track data-scroll-curve="0.72">
              {
                companyLoop.map((company, index) => (
                  <span class="credits-marquee-item" data-loop-copy={Math.floor(index / companies.length)}>
                    {company}
                    {index < companyLoop.length - 1 && <i>•</i>}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="scene writing" id="writing" aria-labelledby="writing-title" data-scroll-bend="0.38">
      <header class="section-heading">
        <p class="section-label">Writing</p>
        <h2 id="writing-title"><ChromaText segments={chroma.writing} /></h2>
      </header>
      <div class="story-list" data-scroll-rib="top">
        {
          site.writing.map((post) => (
            <a class="story-row interactive-row" href={post.url} target="_blank" rel="noreferrer" data-scroll-curve="1.15" data-scroll-rib="bottom">
              <span class="story-meta">
                <time datetime={post.publishedAt}>{post.publishedLabel}</time>
                {` · ${post.readingTime}`}
              </span>
              <h3><ChromaText segments={writingChroma[post.title]} /></h3>
              <span class="row-arrow" aria-hidden="true">↗</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="scene projects" id="projects" aria-labelledby="projects-title" data-scroll-bend="0.56">
      <div class="projects-intro">
        <p class="section-label">Selected work</p>
        <h2 id="projects-title"><ChromaText segments={chroma.projects} /></h2>
      </div>
      <a class="project-primary interactive-panel" href={primaryProject.url} target="_blank" rel="noreferrer" data-scroll-surface="edge" data-scroll-surface-strength="0.9">
        <span class="project-kicker">{primaryProject.category}</span>
        <strong><ChromaText segments={projectChroma[primaryProject.name]} /></strong>
        <span class="project-description">{primaryProject.description}</span>
        <span class="project-action">Open the work ↗</span>
      </a>
      <div class="project-notes" data-scroll-rib="top">
        {
          secondaryProjects.map((project) => (
            <a class="project-note interactive-row" href={project.url} target="_blank" rel="noreferrer" data-scroll-rib="bottom">
              <span class="project-note-meta" data-scroll-curve="0.9">
                <span class="project-note-category">{project.category}</span>
                <Fragment set:html={githubLogoSvg} />
              </span>
              <strong><ChromaText segments={projectChroma[project.name]} /></strong>
              <span class="repository-action" data-scroll-curve="1.05" data-scroll-rib="top">
                <span>View repository</span>
                <span aria-hidden="true">↗</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="scene caipora" id="caipora" aria-labelledby="caipora-title" data-scroll-bend="0.24">
      <article class="caipora-showcase" data-scroll-surface="edge" data-scroll-surface-strength="0.78">
        <div class="caipora-showcase-copy">
          <h2 id="caipora-title">{site.caipora.name}</h2>
          <p class="caipora-kicker">{site.caipora.kicker}</p>
          <p class="caipora-description">{site.caipora.description}</p>

          <ul class="caipora-features" aria-label="Game features">
            {site.caipora.features.map((feature) => <li>{feature}</li>)}
          </ul>

          <a class="caipora-cta" href={site.caipora.url} target="_blank" rel="noreferrer">
            <span>Play Caipora</span>
            <span class="caipora-cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="caipora-visual" role="img" aria-label="Animated pixel-art protagonist from Caipora">
          <div class="caipora-character-stage">
            <div
              class="caipora-character"
              data-caipora-sprite
              style={`background-image: url(${site.caipora.spriteUrl})`}
              aria-hidden="true"
            ></div>
          </div>
          <div class="caipora-visual-label" aria-hidden="true" data-scroll-curve="0.75">
            <span>{site.caipora.playerLabel}</span>
            <span>{site.caipora.atmosphereLabel}</span>
          </div>
        </div>
      </article>
    </section>

    <section class="scene elsewhere" id="elsewhere" data-end-zone aria-labelledby="elsewhere-title" data-scroll-bend="0.42">
      <div class="elsewhere-heading">
        <p class="section-label">Elsewhere</p>
        <h2 id="elsewhere-title"><ChromaText segments={chroma.elsewhere} /></h2>
      </div>
      <nav class="elsewhere-links" aria-label="External profiles" data-scroll-rib="top">
        {
          site.profiles.map((profile) => (
            <a class="interactive-row" href={profile.url} target="_blank" rel="me noreferrer" data-scroll-curve="1.1" data-scroll-rib="bottom">
              <strong><ChromaText segments={profileChroma[profile.label]} /></strong><span>Open ↗</span>
            </a>
          ))
        }
      </nav>
    </section>

    <section class="scene clouds" id="clouds" data-end-zone aria-labelledby="clouds-title" data-scroll-bend="0.54">
      <div class="clouds-copy">
        <h2 id="clouds-title"><ChromaText segments={chroma.clouds} /></h2>
        <div class="spotify-frame">
          <iframe
            title="Clouds on Spotify"
            src={site.clouds.embedUrl}
            width="100%"
            height="352"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          ></iframe>
        </div>
      </div>
    </section>
  </main>

  <div class="end-trail-layer" data-end-trail aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
  </div>

  <footer class="rework-footer" data-scroll-bend="0.62" data-scroll-rib="top">
    <p class="footer-wordmark" aria-hidden="true">baltz.</p>
  </footer>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { scrollMotion } from "../lib/motion/scrollMotion.js";
    import "../lib/motion/scrollBend.js";
    import "../lib/visual/unifiedRenderer.js";

    gsap.registerPlugin(ScrollTrigger);

    const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)");
    const chromaTexts = gsap.utils.toArray<HTMLElement>(".chroma-text");
    type RgbColor = [number, number, number];
    const rootStyles = getComputedStyle(document.documentElement);
    const readTokenColor = (property: string): RgbColor => {
      const value = rootStyles.getPropertyValue(property).trim().replace("#", "");
      const normalized = value.length === 3
        ? value.split("").map((character) => character.repeat(2)).join("")
        : value;
      return [
        Number.parseInt(normalized.slice(0, 2), 16),
        Number.parseInt(normalized.slice(2, 4), 16),
        Number.parseInt(normalized.slice(4, 6), 16),
      ];
    };
    const mixColor = (from: RgbColor, to: RgbColor, progress: number): RgbColor =>
      from.map((channel, index) =>
        Math.round(channel + ((to[index] ?? channel) - channel) * progress),
      ) as RgbColor;
    const colorString = ([red, green, blue]: RgbColor) =>
      `rgb(${red}, ${green}, ${blue})`;
    const mutedColor = mixColor(
      readTokenColor("--color-canvas"),
      readTokenColor("--color-text-muted"),
      0.58,
    );
    const accentColor = readTokenColor("--color-accent-strong");
    const finalColor = readTokenColor("--color-text");
    const projectMutedColor: RgbColor = [22, 11, 7];

    chromaTexts.forEach((text) => {
      const units = [...text.querySelectorAll<HTMLElement>(".chroma-unit")];
      if (units.length === 0) return;
      const isSelectedWorkText = Boolean(text.closest("#projects"));
      const initialColor = isSelectedWorkText ? projectMutedColor : mutedColor;

      gsap.set(units, { color: colorString(initialColor) });
      const chromaClock = { progress: 0 };
      const chromaTimeline = gsap.timeline({
        scrollTrigger: {
          trigger: text,
          start: "top 75%",
          end: isSelectedWorkText ? "top 52%" : "top top",
          scrub: true,
        },
      });
      const lastIndex = Math.max(units.length - 1, 1);
      const staggerRange = isSelectedWorkText ? 0.66 : 0.3;
      const revealDuration = isSelectedWorkText ? 0.34 : 0.22;
      const ranges = units.map((_, index) => {
        const start = (index / lastIndex) * staggerRange;
        const end = Math.min(1, start + revealDuration);
        return { start, end };
      });

      chromaTimeline.to(chromaClock, {
        progress: 1,
        duration: 1,
        ease: "none",
        onUpdate: () => {
          units.forEach((unit, index) => {
            const range = ranges[index];
            if (!range) return;
            const localProgress = Math.max(
              0,
              Math.min(1, (chromaClock.progress - range.start) / (range.end - range.start)),
            );
            const color = localProgress <= 0.18
              ? initialColor
              : localProgress <= 0.58
                ? mixColor(initialColor, accentColor, (localProgress - 0.18) / 0.4)
                : mixColor(accentColor, finalColor, (localProgress - 0.58) / 0.42);
            unit.style.color = colorString(color);
          });
        },
      }, 0);
    });

    const marquee = document.querySelector<HTMLElement>("[data-credits-marquee]");
    const marqueeTrack = marquee?.querySelector<HTMLElement>("[data-credits-track]");

    if (marquee && marqueeTrack) {
        let marqueeFrame = 0;
        let marqueeOffset = 0;
        let marqueeVelocity = -26;
        let marqueeImpulse = 0;
        let marqueeDirection = -1;
        let marqueeCycle = 1;
        let marqueeLastTime = performance.now();
        let marqueeVisible = false;

        const measureMarquee = () => {
          marqueeCycle = Math.max(1, marqueeTrack.scrollWidth / 3);
          marqueeOffset %= marqueeCycle;
        };

        const drawMarquee = (time: number) => {
          marqueeFrame = 0;
          if (!marqueeVisible) return;
          const elapsed = Math.min(48, time - marqueeLastTime) / 1000;
          marqueeLastTime = time;
          marqueeImpulse *= 0.92;
          const marqueeTarget = marqueeDirection * (26 + marqueeImpulse);
          marqueeVelocity += (marqueeTarget - marqueeVelocity) * 0.14;
          marqueeOffset = (marqueeOffset + marqueeVelocity * elapsed) % marqueeCycle;
          if (marqueeOffset > 0) marqueeOffset -= marqueeCycle;
          marqueeTrack.style.transform = `translate3d(${marqueeOffset}px, 0, 0)`;
          marqueeFrame = requestAnimationFrame(drawMarquee);
        };

        const marqueeObserver = new IntersectionObserver(([entry]) => {
          if (!entry) return;
          marqueeVisible = entry.isIntersecting;
          marqueeLastTime = performance.now();
          if (marqueeVisible && !marqueeFrame) {
            marqueeFrame = requestAnimationFrame(drawMarquee);
          }
        }, { rootMargin: "160px 0px" });

        const marqueeResizeObserver = new ResizeObserver(measureMarquee);
        marqueeResizeObserver.observe(marqueeTrack);
        marqueeObserver.observe(marquee);
        measureMarquee();

        scrollMotion.subscribe(({ rawVelocity, direction, energy }) => {
          if (Math.abs(rawVelocity) < 48) return;
          marqueeDirection = direction > 0 ? -1 : 1;
          marqueeImpulse = Math.min(210, energy * 210);
        });
    }

    const caiporaSprite = document.querySelector<HTMLElement>("[data-caipora-sprite]");

    if (caiporaSprite) {
      const idleFrameCount = 5;
      const lastFrameIndex = 6;
      const idleFrameDuration = 1000 / 5;
      const blinkFrameDuration = 1000 / 12;
      let idleFrame = 0;
      let blinkAt = 0;
      let timeoutId: number | undefined;
      let isRunning = false;
      let isInView = false;

      const showCaiporaFrame = (frame: number) => {
        caiporaSprite.style.backgroundPositionX = `${(frame / lastFrameIndex) * 100}%`;
      };

      const scheduleCaiporaBlink = () => {
        blinkAt = Date.now() + 3000 + Math.random() * 3500;
      };

      const playCaiporaIdle = () => {
        if (!isRunning) return;

        if (Date.now() >= blinkAt) {
          showCaiporaFrame(5);
          timeoutId = window.setTimeout(() => {
            if (!isRunning) return;
            showCaiporaFrame(6);
            timeoutId = window.setTimeout(() => {
              if (!isRunning) return;
              scheduleCaiporaBlink();
              playCaiporaIdle();
            }, blinkFrameDuration);
          }, blinkFrameDuration);
          return;
        }

        showCaiporaFrame(idleFrame);
        idleFrame = (idleFrame + 1) % idleFrameCount;
        timeoutId = window.setTimeout(playCaiporaIdle, idleFrameDuration);
      };

      const stopCaiporaAnimation = () => {
        isRunning = false;
        if (timeoutId !== undefined) window.clearTimeout(timeoutId);
      };

      const startCaiporaAnimation = () => {
        if (isRunning || !isInView || document.visibilityState !== "visible") return;
        isRunning = true;
        scheduleCaiporaBlink();
        playCaiporaIdle();
      };

      const caiporaObserver = new IntersectionObserver(([entry]) => {
        if (!entry) return;
        isInView = entry.isIntersecting;
        if (isInView) startCaiporaAnimation();
        else stopCaiporaAnimation();
      }, { rootMargin: "160px 0px", threshold: 0.1 });

      caiporaObserver.observe(caiporaSprite);
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "visible") startCaiporaAnimation();
        else stopCaiporaAnimation();
      });
    }

    if (finePointer.matches) {
      const panels = document.querySelectorAll<HTMLElement>(".interactive-panel, .interactive-row");
      let frame = 0;
      let target: HTMLElement | undefined;
      let x = 0;
      let y = 0;

      const renderPointer = () => {
        frame = 0;
        if (!target) return;
        const rect = target.getBoundingClientRect();
        target.style.setProperty("--pointer-x", `${x - rect.left}px`);
        target.style.setProperty("--pointer-y", `${y - rect.top}px`);
      };

      panels.forEach((panel) => {
        panel.addEventListener("pointermove", (event) => {
          target = panel;
          x = event.clientX;
          y = event.clientY;
          if (!frame) frame = requestAnimationFrame(renderPointer);
        }, { passive: true });
        panel.addEventListener("pointerleave", () => {
          panel.style.removeProperty("--pointer-x");
          panel.style.removeProperty("--pointer-y");
          if (target === panel) target = undefined;
        }, { passive: true });
      });

      const endZones = [...document.querySelectorAll<HTMLElement>("[data-end-zone]")];
      const trail = document.querySelector<HTMLElement>("[data-end-trail]");
      const trailNodes = trail
        ? [...trail.querySelectorAll<HTMLElement>("span")]
        : [];

      if (endZones.length > 0 && trailNodes.length > 0) {
        const points = trailNodes.map(() => ({ x: 0, y: 0 }));
        let trailFrame = 0;
        let trailActive = false;
        let pointerX = 0;
        let pointerY = 0;

        const drawTrail = () => {
          trailFrame = 0;
          if (!trailActive) return;

          const head = points[0];
          if (!head) return;
          head.x += (pointerX - head.x) * 0.34;
          head.y += (pointerY - head.y) * 0.34;

          for (let index = 1; index < points.length; index += 1) {
            const point = points[index];
            const previous = points[index - 1];
            if (!point || !previous) continue;
            point.x += (previous.x - point.x) * 0.25;
            point.y += (previous.y - point.y) * 0.25;
          }

          trailNodes.forEach((node, index) => {
            const point = points[index];
            if (!point) return;
            node.style.transform = `translate3d(${point.x}px, ${point.y}px, 0) translate(-50%, -50%)`;
          });
          endZones.forEach((zone) => {
            const rect = zone.getBoundingClientRect();
            zone.style.setProperty("--end-x", `${head.x - rect.left}px`);
            zone.style.setProperty("--end-y", `${head.y - rect.top}px`);
          });
          trailFrame = requestAnimationFrame(drawTrail);
        };

        const activateTrail = (event: PointerEvent) => {
          pointerX = event.clientX;
          pointerY = event.clientY;
          if (!trailActive) {
            points.forEach((point) => {
              point.x = pointerX;
              point.y = pointerY;
            });
            trailActive = true;
            document.documentElement.dataset.endTrail = "active";
            endZones.forEach((zone) => { zone.dataset.trail = "active"; });
          }
          if (!trailFrame) trailFrame = requestAnimationFrame(drawTrail);
        };

        const deactivateTrail = (event: PointerEvent) => {
          const nextTarget = event.relatedTarget;
          if (endZones.some((zone) => nextTarget instanceof Node && zone.contains(nextTarget))) return;
          trailActive = false;
          document.documentElement.dataset.endTrail = "idle";
          endZones.forEach((zone) => { zone.dataset.trail = "idle"; });
          if (trailFrame) cancelAnimationFrame(trailFrame);
          trailFrame = 0;
        };

        endZones.forEach((zone) => {
          zone.addEventListener("pointerenter", activateTrail, { passive: true });
          zone.addEventListener("pointermove", activateTrail, { passive: true });
          zone.addEventListener("pointerleave", deactivateTrail, { passive: true });
        });
      }
    }
  </script>
</BaseLayout>
