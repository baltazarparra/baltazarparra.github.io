{
  "name": "baltazarparra.github.io",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "tokens": "node scripts/generate-tokens.mjs",
    "og:generate": "node scripts/generate-og.mjs",
    "predev": "node scripts/generate-tokens.mjs",
    "dev": "astro dev --host 0.0.0.0 --port 3100",
    "start": "pnpm dev",
    "check": "astro check",
    "lint": "eslint . --max-warnings 0",
    "prebuild": "node scripts/generate-tokens.mjs",
    "build": "astro check && astro build",
    "artifact:check": "node scripts/check-launch-artifact.mjs",
    "launch:check": "pnpm lint && pnpm build && pnpm artifact:check",
    "lighthouse:ci": "lhci autorun --config=lighthouserc.cjs",
    "lighthouse:desktop": "lhci autorun --config=lighthouserc.desktop.cjs",
    "runtime:measure": "node scripts/measure-runtime.mjs",
    "verify:browser": "node scripts/verify-browser.mjs",
    "preview": "astro preview --host 0.0.0.0 --port 4100"
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@phosphor-icons/react": "^2.1.10",
    "@react-three/fiber": "^9.6.1",
    "gsap": "^3.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.184.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "3.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "lighthouse": "13.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0"
  },
  "packageManager": "pnpm@11.8.0"
}
