---
import SmileStage from "../components/SmileStage.astro";
import ThermalStage from "../components/ThermalStage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <a class="brand" href="#hero" aria-label="Baltz, back to the beginning">b.</a>
    <nav aria-label="Primary navigation">
      {
        site.navigation.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))
      }
    </nav>
  </header>

  <main id="main">
    <section class="hero scene" id="hero">
      <div class="hero-copy">
        <p class="eyebrow hero-beat">{site.hero.eyebrow}</p>
        <h1 class="hero-beat">{site.hero.name}</h1>
        <p class="hero-statement">{site.hero.statement}</p>
        <p class="hero-support hero-beat">{site.hero.support}</p>
      </div>
      <div class="smile-stage hero-object">
        <SmileStage />
      </div>
    </section>

    <section class="about scene settle-scene" id="work">
      <figure
        class="portrait resilient-media settle-item"
        data-resilient-media
        data-media-state="ready"
      >
        <span class="media-fallback portrait-fallback" aria-hidden="true">b.</span>
        <img
          src="/baltz-portrait.jpg"
          alt="Portrait of Baltz"
          width="1024"
          height="1280"
          decoding="async"
          data-resilient-image
        />
      </figure>
      <div class="about-copy settle-item">
        <h2>{site.about.heading}</h2>
        <p>{site.about.body}</p>
        <p class="credits">{site.about.credits}</p>
      </div>
    </section>

    <section class="writing scene settle-scene" id="writing" aria-labelledby="writing-title">
      <div class="writing-heading settle-item">
        <h2 id="writing-title">Writing.</h2>
      </div>
      <div class="writing-list">
        {
          site.writing.map((post) => (
            <article class="writing-entry settle-item">
              <p class="writing-meta">
                <time datetime={post.publishedAt}>{post.publishedLabel}</time>
                <span>{post.readingTime}</span>
              </p>
              <h3>{post.title}</h3>
              <a
                class="text-link"
                href={post.url}
                target="_blank"
                rel="noreferrer"
                aria-label={`Read ${post.title} on dev.to`}
              >
                Read on dev.to
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="projects scene" aria-labelledby="projects-title">
      <div class="project-lead">
        <p>Selected systems</p>
        <h2 id="projects-title">Work that explains how I think.</h2>
      </div>
      <div class="project-stack">
        {
          site.projects.map((project) => (
            <article class="project-entry">
              <p>{project.category}</p>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <a
                class="text-link"
                href={project.url}
                target="_blank"
                rel="noreferrer"
                aria-label={`Open ${project.name}`}
              >
                Open project
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="caipora scene settle-scene" id="caipora">
      <div
        class="media-window resilient-media settle-item"
        data-resilient-media
        data-media-state="ready"
      >
        <span class="media-fallback caipora-fallback" aria-hidden="true">CAIPORA</span>
        <img
          src="/caipora.jpeg"
          alt="Caipora game title screen"
          width="1600"
          height="900"
          loading="lazy"
          decoding="async"
          data-resilient-image
        />
      </div>
      <div class="caipora-copy settle-item">
        <h2>{site.caipora.name}</h2>
        <p>{site.caipora.description}</p>
        <a class="text-link" href={site.caipora.url} target="_blank" rel="noreferrer">
          Play in browser
        </a>
      </div>
    </section>

    <div class="thermal-cut" aria-hidden="true">
      <ThermalStage />
    </div>

    <section class="clouds scene settle-scene">
      <div
        class="clouds-cover resilient-media settle-item"
        data-resilient-media
        data-media-state="ready"
        data-fallback-persistent
      >
        <span aria-hidden="true">CLOUDS</span>
        <img
          src={site.clouds.coverUrl}
          alt="Clouds EP cover"
          width="640"
          height="640"
          loading="lazy"
          decoding="async"
          referrerpolicy="no-referrer"
          data-resilient-image
        />
      </div>
      <div class="clouds-copy settle-item">
        <h2>{site.clouds.name}</h2>
        <p>{site.clouds.description}</p>
        <a class="text-link" href={site.clouds.url} target="_blank" rel="noreferrer">
          Listen on Spotify
        </a>
      </div>
    </section>

    <section class="elsewhere scene settle-scene" id="elsewhere">
      <h2 class="settle-item">Elsewhere.</h2>
      <nav class="profile-links settle-item" aria-label="External profiles">
        {
          site.profiles.map((profile) => (
            <a href={profile.url} target="_blank" rel="me noreferrer">
              {profile.label}
            </a>
          ))
        }
      </nav>
      <footer>
        <span>baltz.dev</span>
        <span>Built and edited by Baltz.</span>
      </footer>
    </section>
  </main>

  <script>
    let disposeMotion = () => {};
    let disposed = false;

    const startMotion = async () => {
      if (
        disposed ||
        window.matchMedia("(prefers-reduced-motion: reduce)").matches
      ) {
        return;
      }
      const { initPinnedEdit } = await import("../lib/motion/pinnedEdit");
      if (disposed) return;
      disposeMotion = initPinnedEdit();
    };

    const idleWindow = window as unknown as {
      requestIdleCallback?: (
        callback: IdleRequestCallback,
        options?: IdleRequestOptions,
      ) => number;
      cancelIdleCallback?: (handle: number) => void;
    };
    let motionHandle: number;
    if (idleWindow.requestIdleCallback) {
      motionHandle = idleWindow.requestIdleCallback(() => void startMotion(), {
        timeout: 1_200,
      });
    } else {
      motionHandle = window.setTimeout(() => void startMotion(), 250);
    }

    if (import.meta.hot) {
      import.meta.hot.dispose(() => {
        disposed = true;
        if (idleWindow.cancelIdleCallback) {
          idleWindow.cancelIdleCallback(motionHandle);
        } else {
          window.clearTimeout(motionHandle);
        }
        disposeMotion();
      });
    }
  </script>

  <script>
    const mediaTimeout = 8_000;
    const mediaRoots = document.querySelectorAll<HTMLElement>(
      "[data-resilient-media]",
    );

    const prepareMedia = (root: HTMLElement) => {
      const image = root.querySelector<HTMLImageElement>("[data-resilient-image]");
      if (!image) return;

      if (image.complete) {
        root.dataset.mediaState = image.naturalWidth > 0 ? "ready" : "error";
        return;
      }

      const settle = (state: "ready" | "error" | "timeout") => {
        window.clearTimeout(timeoutId);
        root.dataset.mediaState = state;
      };

      root.dataset.mediaState = "loading";
      image.addEventListener("load", () => settle("ready"), { once: true });
      image.addEventListener("error", () => settle("error"), { once: true });
      const timeoutId = window.setTimeout(
        () => settle("timeout"),
        mediaTimeout,
      );
    };

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            observer.unobserve(entry.target);
            prepareMedia(entry.target as HTMLElement);
          });
        },
        { rootMargin: "100% 0px" },
      );
      mediaRoots.forEach((root) => observer.observe(root));
    } else {
      mediaRoots.forEach(prepareMedia);
    }
  </script>
</BaseLayout>
