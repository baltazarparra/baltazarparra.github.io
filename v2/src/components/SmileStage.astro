<div
  class="smile-island is-fallback"
  data-smile-root
  data-smile-state="poster"
>
  <span class="smile-fallback" aria-hidden="true"><i></i></span>
</div>

<script>
  const smileRoot = document.querySelector<HTMLElement>("[data-smile-root]");
  const supportsInteractiveSmile =
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (smileRoot && supportsInteractiveSmile) {
    const importTimeout = 8_000;
    const activate = async () => {
      smileRoot.dataset.smileState = "loading";
      try {
        const modules = Promise.all([
          import("react"),
          import("react-dom/client"),
          import("../islands/SmileScene"),
        ]);
        const timeout = new Promise<never>((_, reject) => {
          window.setTimeout(
            () => reject(new Error("Smile module timed out")),
            importTimeout,
          );
        });
        const [{ createElement }, { createRoot }, { SmileScene }] =
          await Promise.race([modules, timeout]);
        createRoot(smileRoot).render(createElement(SmileScene));
        smileRoot.dataset.smileState = "interactive";
      } catch {
        smileRoot.dataset.smileState = "poster";
      }
    };

    const activateFromIntent = (event: PointerEvent) => {
      if (event.pointerType !== "mouse" && event.pointerType !== "pen") return;
      smileRoot.removeEventListener("pointerenter", activateFromIntent);
      void activate();
    };

    smileRoot.addEventListener("pointerenter", activateFromIntent, {
      passive: true,
    });
  }
</script>
