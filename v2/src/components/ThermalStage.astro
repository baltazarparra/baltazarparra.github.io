<div class="thermal-island" data-thermal-root data-thermal-state="fallback">
  <span class="thermal-fallback"></span>
</div>

<script>
  const thermalRoot = document.querySelector<HTMLElement>("[data-thermal-root]");
  const supportsThermalWebGL =
    window.innerWidth >= 768 &&
    navigator.maxTouchPoints === 0 &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (thermalRoot && supportsThermalWebGL) {
    const importTimeout = 8_000;
    const observer = new IntersectionObserver(
      async (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        observer.disconnect();
        thermalRoot.dataset.thermalState = "loading";
        try {
          const modules = Promise.all([
            import("react"),
            import("react-dom/client"),
            import("../islands/ThermalField"),
          ]);
          const timeout = new Promise<never>((_, reject) => {
            window.setTimeout(
              () => reject(new Error("Thermal module timed out")),
              importTimeout,
            );
          });
          const [{ createElement }, { createRoot }, { ThermalField }] =
            await Promise.race([modules, timeout]);
          createRoot(thermalRoot).render(createElement(ThermalField));
          thermalRoot.dataset.thermalState = "interactive";
        } catch {
          thermalRoot.dataset.thermalState = "fallback";
        }
      },
      { rootMargin: "18% 0px" },
    );

    observer.observe(thermalRoot);
  }
</script>
